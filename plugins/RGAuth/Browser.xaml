<Window x:Class="RGAuth.Browser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RGAuth"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Closing="Window_Closing"
        Focusable="False"
        Title="Browser" Height="450" Width="800">
    <Grid x:Name="browserGrid">
        <Canvas x:Name="browserCnv">
            <WebBrowser x:Name="auth_webBrowser" Navigating="auth_webBrowser_Navigating" Height="434" Width="800" LoadCompleted="auth_webBrowser_LoadCompleted"/>
        </Canvas>
    </Grid>
</Window>
